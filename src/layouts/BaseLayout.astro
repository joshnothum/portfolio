---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Josh Nothum | Portfolio',
  description = 'Software engineer portfolio for Josh Nothum.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <canvas id="starfield" aria-hidden="true"></canvas>
    <slot />
    <script>
      const canvas = document.getElementById('starfield') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      type Star = {
        x: number; y: number; r: number;
        opacity: number; speed: number;
        wobble: number; wobbleSpeed: number;
        color: string;
      };

      const palette = ['#dde6f5', '#dde6f5', '#c4a45a', '#4a9b8e'];
      const stars: Star[] = Array.from({ length: 130 }, () => ({
        x: Math.random(),
        y: Math.random(),
        r: Math.random() * 1.6 + 0.3,
        opacity: Math.random() * 0.55 + 0.15,
        speed: Math.random() * 0.00008 + 0.00002,
        wobble: Math.random() * Math.PI * 2,
        wobbleSpeed: Math.random() * 0.008 + 0.003,
        color: palette[Math.floor(Math.random() * palette.length)],
      }));

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const s of stars) {
          s.wobble += s.wobbleSpeed;
          s.y -= s.speed;
          if (s.y < 0) s.y = 1;
          const x = s.x * canvas.width + Math.sin(s.wobble) * 12;
          const y = s.y * canvas.height;
          ctx.beginPath();
          ctx.arc(x, y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = s.color;
          ctx.globalAlpha = s.opacity * (0.75 + 0.25 * Math.sin(s.wobble * 0.4));
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(draw);
      }

      resize();
      window.addEventListener('resize', resize);
      requestAnimationFrame(draw);
    </script>
  </body>
</html>
